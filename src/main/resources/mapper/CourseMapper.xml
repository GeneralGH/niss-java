<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nanyang.academy.mapper.CourseMapper">

	<select id="getCourseListPage" resultType="com.nanyang.academy.entity.dto.CourseVo">
		select t.*,u.nick_name create_name
		from course t
				 left join sys_user u on t.create_by = u.user_id
			${ew.customSqlSegment}
	</select>

</mapper>
