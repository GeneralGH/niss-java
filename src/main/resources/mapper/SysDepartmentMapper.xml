<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
		"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.nanyang.academy.mapper.SysDepartmentMapper">
	<resultMap type="com.nanyang.academy.entity.SysDepartment" id="SysDeptResult">
		<id     property="deptId"     column="dept_id"     />
		<result property="pId"   column="p_id"   />
		<result property="deptName"   column="dept_name"   />
		<result property="ancestors"  column="ancestors"   />
		<result property="sort"   column="sort"   />
		<result property="status"     column="status"      />
		<result property="isDelete"    column="is_delete"    />
		<result property="leader"     column="leader"      />
		<result property="phone"      column="phone"       />
		<result property="email"      column="email"       />
		<result property="pName" column="p_name" />
		<result property="createUser"   column="create_user"   />
		<result property="createTime" column="create_time" />
		<result property="updateUser"   column="update_user"   />
		<result property="updateTime" column="update_time" />
	</resultMap>

	<sql id="selectDeptVo">
		select d.dept_id, d.p_id, d.dept_name, d.is_delete,
			   d.ancestors,d.leader, d.phone, d.email,d.status,
		       d.create_user, d.create_time
		from sys_department d
	</sql>
	<select id="selectDeptById" parameterType="Long" resultMap="SysDeptResult">
		<include refid="selectDeptVo"/>
		where dept_id = #{deptId}
	</select>
	<select id="selectDeptByAncestors" parameterType="Long" resultType="Long">
		SELECT t.dept_id FROM sys_department t WHERE t.is_delete = 0 and find_in_set(#{deptId}, ancestors)
	</select>

	<select id="selectDeptList" parameterType="com.nanyang.academy.entity.SysDepartment" resultMap="SysDeptResult">
		<include refid="selectDeptVo"/>
		where d.is_delete = 0
		<if test="deptId != null and deptId != 0">
			AND dept_id = #{deptId}
		</if>
		<if test="pId != null and pId != 0">
			AND p_id = #{pId}
		</if>
		<if test="deptName != null and deptName != ''">
			AND dept_name like concat('%', #{deptName}, '%')
		</if>
		<if test="status != null and status != ''">
			AND status = #{status}
		</if>
		order by d.p_id, d.sort
	</select>

	<select id="selectDeptListPage" parameterType="com.nanyang.academy.entity.SysDepartment" resultMap="SysDeptResult">
		<include refid="selectDeptVo"/>
		${ew.customSqlSegment}
	</select>

	<select id="selectDeptListByRoleId" resultType="Long">
		select d.dept_id
		from SysDepartment d
		left join sys_role_dept rd on d.dept_id = rd.dept_id
		where rd.role_id = #{roleId} and d.is_delete = 0
		<if test="deptCheckStrictly">
			and d.dept_id not in (select d.p_id from SysDepartment d inner join sys_role_dept rd on d.dept_id = rd.dept_id and rd.role_id = #{roleId})
		</if>
		order by d.p_id, d.sort
	</select>


	<select id="checkDeptExistUser" parameterType="Long" resultType="int">
		select count(1) from sys_user where dept_id = #{deptId} and is_delete = 0
	</select>

	<select id="hasChildByDeptId" parameterType="Long" resultType="int">
		select count(1) from SysDepartment
		where is_delete = 0 and p_id = #{deptId} limit 1
	</select>

	<select id="selectChildrenDeptById" parameterType="Long" resultMap="SysDeptResult">
		select * from SysDepartment where find_in_set(#{deptId}, ancestors)
	</select>

	<select id="selectNormalChildrenDeptById" parameterType="Long" resultType="int">
		select count(*) from SysDepartment where status = 0 and is_delete = 0 and find_in_set(#{deptId}, ancestors)
	</select>

	<select id="checkDeptNameUnique" resultMap="SysDeptResult">
		<include refid="selectDeptVo"/>
		where dept_name=#{deptName} and p_id = #{pId} limit 1
	</select>

	<insert id="insertDept" parameterType="com.nanyang.academy.entity.SysDepartment">
		insert into SysDepartment(
		<if test="deptId != null and deptId != 0">dept_id,</if>
		<if test="pId != null and pId != 0">p_id,</if>
		<if test="deptName != null and deptName != ''">dept_name,</if>
		<if test="ancestors != null and ancestors != ''">ancestors,</if>
		<if test="sort != null">sort,</if>
		<if test="leader != null and leader != ''">leader,</if>
		<if test="phone != null and phone != ''">phone,</if>
		<if test="email != null and email != ''">email,</if>
		<if test="status != null">status,</if>
		<if test="createUser != null and createUser != ''">create_user,</if>
		create_time
		)values(
		<if test="deptId != null and deptId != 0">#{deptId},</if>
		<if test="pId != null and pId != 0">#{pId},</if>
		<if test="deptName != null and deptName != ''">#{deptName},</if>
		<if test="ancestors != null and ancestors != ''">#{ancestors},</if>
		<if test="sort != null">#{sort},</if>
		<if test="leader != null and leader != ''">#{leader},</if>
		<if test="phone != null and phone != ''">#{phone},</if>
		<if test="email != null and email != ''">#{email},</if>
		<if test="status != null">#{status},</if>
		<if test="createUser != null and createUser != ''">#{createUser},</if>
		sysdate()
		)
	</insert>

	<update id="updateDept" parameterType="com.nanyang.academy.entity.SysDepartment">
		update SysDepartment
		<set>
			<if test="pId != null and pId != 0">p_id = #{pId},</if>
			<if test="deptName != null and deptName != ''">dept_name = #{deptName},</if>
			<if test="ancestors != null and ancestors != ''">ancestors = #{ancestors},</if>
			<if test="sort != null">sort = #{sort},</if>
			<if test="leader != null">leader = #{leader},</if>
			<if test="phone != null">phone = #{phone},</if>
			<if test="email != null">email = #{email},</if>
			<if test="status != null and status != ''">status = #{status},</if>
			<if test="updateUser != null and updateUser != ''">update_user = #{updateUser},</if>
			update_time = sysdate()
		</set>
		where dept_id = #{deptId}
	</update>

	<update id="updateDeptChildren" parameterType="java.util.List">
		update SysDepartment set ancestors =
		<foreach collection="depts" item="item" index="index"
				 separator=" " open="case dept_id" close="end">
			when #{item.deptId} then #{item.ancestors}
		</foreach>
		where dept_id in
		<foreach collection="depts" item="item" index="index"
				 separator="," open="(" close=")">
			#{item.deptId}
		</foreach>
	</update>

	<update id="updateDeptStatusNormal" parameterType="Long">
		update SysDepartment set status = 0 where dept_id in
		<foreach collection="array" item="deptId" open="(" separator="," close=")">
			#{deptId}
		</foreach>
	</update>

	<delete id="deleteDeptById" parameterType="Long">
		update sys_dept set is_delete = '1' where dept_id = #{deptId}
	</delete>
</mapper>
